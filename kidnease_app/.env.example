# Kidnease API Configuration
# Copy this file to .env and fill in your actual API keys

# Gemini AI API Key (for food image analysis)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# FatSecret API Credentials (for nutritional database)
# Get from: https://platform.fatsecret.com/api/
FATSECRET_KEY=your_fatsecret_consumer_key_here
FATSECRET_SECRET=your_fatsecret_consumer_secret_here
